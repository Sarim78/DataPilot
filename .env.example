# --- Gemini / ADK (agent/) ---
# Vertex AI (ADC): set project + location, run: gcloud auth application-default login
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your_project_id_here
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# Google AI Studio fallback (personal account): set FALSE and use API key instead
# GOOGLE_GENAI_USE_VERTEXAI=FALSE
# GOOGLE_API_KEY=your_google_api_key_here

# Vertex Express Mode (optional): GOOGLE_GENAI_API_KEY=your_express_mode_key

MONGODB_URI=mongodb://localhost:27017

MONGODB_DB_NAME=datapilot